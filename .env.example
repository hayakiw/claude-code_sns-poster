# claude-sns 環境変数テンプレート
# このファイルを .env にコピーして値を埋める（.env は .gitignore で除外される）。
#   cp .env.example .env
# sns-cycle は各 API 呼び出しの前に .env を読み込む（set -a; . ./.env; set +a）。

# --- サムネイル画像生成（OpenAI Image API）---
# 設定すると承認分のサムネを gpt-image-1 で生成。未設定なら画像はスキップしプロンプトのみ残す。
OPENAI_API_KEY=

# --- Typefully（下書きキュー・反応分析）---
# LIVE=1 かつ TYPEFULLY_API_KEY があるときだけ Typefully に下書き登録・計測する。
TYPEFULLY_API_KEY=
LIVE=0
